{
  "rewrites": [
    { "source": "/blog/:slug", "destination": "/api/blog-og?slug=$slug" }
  ],
  "redirects": [
    { "source": "/appointment",    "destination": "https://drshreydhawan.wixsite.com/website-16/appointment", "statusCode": 301 },
    { "source": "/appointment/(.*)", "destination": "https://drshreydhawan.wixsite.com/website-16/appointment", "statusCode": 301 },
    { "source": "/booking",        "destination": "https://drshreydhawan.wixsite.com/website-16/appointment", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
