{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/appointment",      "destination": "/book-appointment", "statusCode": 301 },
    { "source": "/appointment/(.*)", "destination": "/book-appointment", "statusCode": 301 },
    { "source": "/booking",          "destination": "/book-appointment", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
